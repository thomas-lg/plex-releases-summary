ARG PYTHON_VERSION=3.14-slim
FROM python:${PYTHON_VERSION}

# Metadata labels
LABEL org.opencontainers.image.title="Plex Releases Summary (Dev)"
LABEL org.opencontainers.image.description="Development container for Plex Releases Summary — includes dev dependencies, linting, and test tooling"
LABEL org.opencontainers.image.authors="thomas-lg"
LABEL org.opencontainers.image.url="https://github.com/thomas-lg/plex-releases-summary"
LABEL org.opencontainers.image.source="https://github.com/thomas-lg/plex-releases-summary"
LABEL org.opencontainers.image.documentation="https://github.com/thomas-lg/plex-releases-summary/blob/main/CONTRIBUTING.md"
LABEL org.opencontainers.image.licenses="MIT"

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-dev.txt requirements.lock requirements-dev.lock ./

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements-dev.lock
